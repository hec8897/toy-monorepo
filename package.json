{
  "name": "toy-monorepo",
  "version": "1.0.0",
  "description": "토이프로젝트 모노레포",
  "packageManager": "pnpm@10.33.0",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "nx serve backend",
    "dev:frontend": "nx dev frontend",
    "dev:portfolio": "nx dev portfolio",
    "dev:devjournal": "concurrently \"npm:dev:devjournal-backend\" \"npm:dev:devjournal-frontend\"",
    "dev:devjournal-backend": "lsof -ti:3002 | xargs kill -9 2>/dev/null; nx serve devjournal-backend",
    "dev:devjournal-frontend": "nx run devjournal-frontend:dev",
    "build:devjournal-frontend": "nx build devjournal-frontend",
    "build": "nx run-many --target=build --projects=backend,frontend --parallel",
    "build:backend": "nx build backend",
    "build:frontend": "nx build frontend",
    "build:portfolio": "nx build portfolio",
    "build:devjournal-backend": "nx build devjournal-backend",
    "test": "nx run-many --target=test --all",
    "test:backend": "nx test backend",
    "test:frontend": "nx test frontend",
    "lint": "nx run-many --target=lint --all",
    "lint:backend": "nx lint backend",
    "lint:frontend": "nx lint frontend",
    "graph": "nx graph",
    "affected:graph": "nx affected:graph",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
