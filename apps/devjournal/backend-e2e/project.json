{
  "name": "devjournal-backend-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["devjournal-backend"],
  "projectType": "application",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/devjournal/backend-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["devjournal-backend:build", "devjournal-backend:serve"]
    }
  }
}
